{
  "name": "tailwindcss-cursor-effects",
  "version": "1.0.0",
  "description": "Tailwind CSS plugin for advanced interactive cursor experiences",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "playground": "npx @tailwindcss/cli -i ./playground/input.css -o ./playground/output.css --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "tailwind-plugin",
    "plugin",
    "css",
    "cursor",
    "mouse",
    "pointer",
    "magnetic",
    "spotlight",
    "hover",
    "effects",
    "animation",
    "interaction",
    "physics",
    "trail",
    "awwwards"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nidhidipak/tailwindcss-cursor-effects.git"
  },
  "bugs": {
    "url": "https://github.com/nidhidipak/tailwindcss-cursor-effects/issues"
  },
  "homepage": "https://github.com/nidhidipak/tailwindcss-cursor-effects#readme",
  "author": "nidhidipak",
  "license": "MIT",
  "peerDependencies": {
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
